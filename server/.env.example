# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/lastpiece

# JWT
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_REFRESH_EXPIRES=7d

# Cookies & CORS
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000

# SMS Aero
SMSAERO_EMAIL=
SMSAERO_API_KEY=
SMSAERO_SIGN=SMS Aero
SMSAERO_CHANNEL=DIRECT
NOTIFY_SMS_ENABLED=true
NOTIFY_SMS_SELLER_EVENTS=true

# OTP
OTP_TTL_SEC=300
OTP_RESEND_SEC=60
OTP_MAX_ATTEMPTS=5

# Uploads
UPLOAD_MAX_FILES=10
UPLOAD_MAX_MB=5
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp
IMGUR_CLIENT_ID=
